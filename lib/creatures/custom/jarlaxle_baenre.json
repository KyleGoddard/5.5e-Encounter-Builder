    "traits": [   
      {                                                                                                                                                                                                                                                                                                                      
        "name": "Special Equipment",
        "description": "Jarlaxle wears +3 leather armor, a hat of disguise, a bracer of flying daggers, a cloak of invisibility, a knave's eye patch, and a ring of truth telling. He wields a +3 rapier and carries a portable hole and a wand of web. His hat is adorned with a feather of diatryma summoning."            
      },                                                                                                                                                                                                                                                                                                                     
      {
        "name": "Evasion",                                                                                                                                                                                                                                                                                                   
        "description": "If Jarlaxle is subjected to an effect that allows him to make a Dexterity saving throw to take only half damage, he instead takes no damage if he succeeds on the saving throw, and only half damage if he fails. He can't use this trait if he's Incapacitated."
      },                                                                                                                                                                                                                                                                                                                     
      {
        "name": "Fey Ancestry",                                                                                                                                                                                                                                                                                              
        "description": "Jarlaxle has Advantage on saving throws against being Charmed, and magic can't put him to sleep."
      },                                                                                                                                                                                                                                                                                                                     
      {
        "name": "Innate Spellcasting",                                                                                                                                                                                                                                                                                       
        "description": "Jarlaxle's innate spellcasting ability is Charisma (spell save DC 17, +9 to hit with spell attacks). He can innately cast the following spells, requiring no material components. At will: dancing lights. 1/day each: darkness, faerie fire, levitate (self only)."
      },                                                                                                                                                                                                                                                                                                                     
      {
        "name": "Legendary Resistance (1/Day)",                                                                                                                                                                                                                                                                              
        "description": "If Jarlaxle fails a saving throw, he can choose to succeed instead."
      },
      {                                                                                                                                                                                                                                                                                                                      
        "name": "Master Attuner",
        "description": "Jarlaxle can attune to up to five magic items, and he can attune to magic items that normally require attunement by a sorcerer, warlock, or wizard."                                                                                                                                                 
      },          
      {                                                                                                                                                                                                                                                                                                                      
        "name": "Sneak Attack (1/Turn)",
        "description": "Jarlaxle deals an extra 24 (7d6) damage when he hits a target with a weapon attack and has Advantage on the attack roll, or when the target is within 5 feet of an ally of Jarlaxle's that isn't Incapacitated and Jarlaxle doesn't have Disadvantage on the attack roll."                           
      },                                                                                                                                                                                                                                                                                                                     
      {
        "name": "Suave Defense",                                                                                                                                                                                                                                                                                             
        "description": "While Jarlaxle is wearing light or no armor and wielding no shield, his AC includes his Charisma modifier."                                                                                                                                                                                          
      },
      {                                                                                                                                                                                                                                                                                                                      
        "name": "Sunlight Sensitivity",
        "description": "When not wearing his knave's eye patch, Jarlaxle has Disadvantage on attack rolls, as well as on Wisdom (Perception) checks that rely on sight."
      }                                                                                                                                                                                                                                                                                                                      
    ],
    "actions": [                                                                                                                                                                                                                                                                                                             
      {           
        "name": "Multiattack",
        "description": "Jarlaxle makes three attacks with his +3 rapier or two attacks with daggers created by his bracer of flying daggers."                                                                                                                                                                                
      },
      {                                                                                                                                                                                                                                                                                                                      
        "name": "+3 Rapier",
        "description": "Melee Weapon Attack: +14 to hit, reach 5 ft., one target. Hit: 13 (1d8 + 9) Piercing damage."
      },                                                                                                                                                                                                                                                                                                                     
      {
        "name": "Flying Dagger",                                                                                                                                                                                                                                                                                             
        "description": "Ranged Weapon Attack: +11 to hit, range 20/60 ft., one target. Hit: 8 (1d4 + 6) Piercing damage."
      }                                                                                                                                                                                                                                                                                                                      
